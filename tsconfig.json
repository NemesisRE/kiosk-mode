{
  "compilerOptions": {
    "outDir": "./dist/",
    "module": "esnext",
    "target": "es6",
    "moduleResolution": "bundler",
    "types": ["node"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": false,
    "noImplicitAny": true,
    "removeComments": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "paths": {
      "@types": ["./src/types"],
      "@constants": ["./src/constants"],
      "@utilities": ["./src/utilities"],
      "@styles": ["./src/styles"]   
    }
  },
  "include": [
    "src/**/*.ts",
    "package.json",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules"]
}